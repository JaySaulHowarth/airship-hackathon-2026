# Copy to `.env.local` for local development (never commit real secrets).

# MongoDB connection (local mongod, Docker, or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017

# Database name (optional; defaults to `table_order`)
# MONGODB_DB=table_order

# Staff-only access for `GET /api/orders` (query `?pin=`, `Authorization: Bearer`, or cookie from `POST /api/staff/session`)
STAFF_PIN=change-me
